# Runtime
NODE_ENV=development
PORT=4000
# Internal core API port used by gateway.ts. Defaults to PORT + 1.
INTERNAL_API_PORT=4001
# Comma-separated exact browser origins. REQUIRED in production.
ALLOWED_ORIGINS=http://localhost:3000

# Authentication
APP_PASSCODE=
CRON_SHARED_SECRET=

# Encryption
AI_CREDENTIAL_ENCRYPTION_KEY=
SESSION_SECRET=

# PostgreSQL / Prisma
DATABASE_URL=
DIRECT_URL=

# AI providers
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
AI_API_KEY=
AI_PROVIDER=openrouter
AI_MODEL=openrouter/free
