# ---- Backend environment ----
# Copy to .env and fill in. Do NOT commit real secrets.

# Server port.
PORT=4000

# Auth. APP_PASSCODE MUST match the frontend value.
APP_PASSCODE=
# Shared secret required to call the /cron/* endpoints.
CRON_SHARED_SECRET=

# Encryption key for AI provider keys stored in the database.
# If unset, the code falls back to SESSION_SECRET. Set at least one, 32+ chars.
AI_CREDENTIAL_ENCRYPTION_KEY=
SESSION_SECRET=

# Database (Supabase Postgres). DIRECT_URL is used for migrations.
DATABASE_URL=
DIRECT_URL=

# AI providers. Set the key for whichever provider(s) you use.
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
# Legacy alias also accepted for the OpenRouter key.
AI_API_KEY=

# Default active provider: openrouter | nvidia | cerebras
AI_PROVIDER=openrouter
# Default model id (used for OpenRouter).
AI_MODEL=openrouter/free
