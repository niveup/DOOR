generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Settings {
  id                  String    @id @default("default")
  name                String
  targetExam          String    @default("GATE")
  targetYear          Int       @default(2027)
  dailyAvailableHours Float     @default(4.0)
  preferredLanguage   String    @default("hinglish")
  timezone            String    @default("Asia/Kolkata")
  wakeTime            String    @default("06:00")
  sleepTime           String    @default("22:00")
  exerciseGoal        String?
  otherGoals          Json?
  prepLevel           String    @default("Beginner")
  scoreWeights        Json?
  pushSubscription    Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  analysisStale       Boolean   @default(false)
  analysisWeekOf      DateTime? @db.Date
  weeklyAnalysis      String?
}

model Subject {
  subjectId       Int                  @id
  subjectName     String
  importanceLevel Float
  topics          Json
  explanations    ConceptExplanation[]
  ratings         ProgressRating[]
  StudyLog        StudyLog[]
  tasks           Task[]
  topicStatuses   TopicStatus[]
}

model ProgressRating {
  ratingId         String   @id @default(uuid())
  subjectId        Int
  weekStartDate    DateTime @db.Date
  selfRating       Int
  hoursStudied     Float    @default(0.0)
  questionsSolved  Int      @default(0)
  confidenceLevel  Int      @default(3)
  revisionStatus   String   @default("NOT_STARTED")
  notes            String?
  aiRecommendation String?
  createdAt        DateTime @default(now())
  subject          Subject  @relation(fields: [subjectId], references: [subjectId])

  @@unique([subjectId, weekStartDate])
}

model StudyLog {
  id              String   @id @default(uuid())
  logDate         String
  timeBlock       String   @default("Evening")
  subjectId       Int
  subjectName     String
  hoursStudied    Float    @default(0)
  questionsSolved Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  subject         Subject  @relation(fields: [subjectId], references: [subjectId], onDelete: Cascade)

  @@index([logDate])
  @@index([subjectId])
}

model TopicStatus {
  topicStatusId     String   @id
  subjectId         Int
  topicId           String
  status            String   @default("NOT_STARTED")
  lastExplanationId String?
  lastScore         Int?
  updatedAt         DateTime @updatedAt
  subject           Subject  @relation(fields: [subjectId], references: [subjectId])

  @@unique([subjectId, topicId])
}

model Task {
  taskId      String      @id
  date        DateTime    @db.Date
  planId      String
  title       String
  taskType    String
  subjectId   Int?
  topicId     String?
  durationMin Int
  status      String      @default("NOT")
  isPriority  Boolean     @default(false)
  isCarryover Boolean     @default(false)
  createdAt   DateTime    @default(now())
  finalizedAt DateTime?
  RoutinePlan RoutinePlan @relation(fields: [planId], references: [planId], onDelete: Cascade)
  subject     Subject?    @relation(fields: [subjectId], references: [subjectId])
}

model ConceptExplanation {
  explanationId      String   @id
  topicInput         String
  normalizedTopic    String
  subjectId          Int?
  mode               String
  difficulty         String   @default("Medium")
  explanationText    String
  questions          Json?
  finalScore         Int?
  topicStatusSet     Boolean  @default(false)
  formulaGuardPassed Boolean  @default(true)
  createdAt          DateTime @default(now())
  subject            Subject? @relation(fields: [subjectId], references: [subjectId])
}

model AiCallLog {
  logId           String   @id
  surface         String
  latencyMs       Int
  success         Boolean
  errorMessage    String?
  promptPreview   String?
  responsePreview String?
  createdAt       DateTime @default(now())
}

model AiProviderCredential {
  provider        String   @id
  encryptedApiKey String
  encryptionIv    String
  authTag         String
  keyHint         String
  model           String
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([isActive])
}

model InterviewAttempt {
  attemptId            String   @id
  sessionId            String
  company              String
  mode                 String
  questionIndex        Int
  questionText         String
  userAnswer           String
  skipped              Boolean  @default(false)
  score                Float
  dimensions           Json?
  missingPoints        Json?
  improvedAnswer       String?
  improvedAnswerViewed Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@unique([sessionId, questionIndex])
  @@index([sessionId, createdAt])
}

model Journal {
  journalId       String    @id
  date            DateTime  @unique @db.Date
  entryText       String
  mood            String?
  tags            Json?
  aiFeedback      String?
  tomorrowTask    String?
  patternDetected String?
  studyDone       Boolean   @default(false)
  exerciseDone    Boolean   @default(false)
  readingDone     Boolean   @default(false)
  helpfulness     Int?
  createdAt       DateTime  @default(now())
  editedAt        DateTime
  lockedAt        DateTime?
}

model RoutinePlan {
  planId            String   @id
  date              DateTime @unique @db.Date
  greeting          String
  planText          String
  mainPriority      String
  totalEstimatedMin Int      @default(0)
  isWeekend         Boolean  @default(false)
  generatedAt       DateTime @default(now())
  Task              Task[]
}

model WeeklyReport {
  reportId           String   @id
  weekStartDate      DateTime @unique @db.Date
  avgDailyScore      Float
  totalStudyHours    Float
  completedTasks     Int
  missedTasks        Int
  streaksSummary     Json
  biggestImprovement String
  biggestProblem     String
  aiSummary          String
  generatedAt        DateTime @default(now())
}
