# Runtime: production on Vercel, development locally.
NODE_ENV=development

# Signed iron-session secret, minimum 32 characters.
SESSION_SECRET=
# Shared only between Vercel server routes and Render. Never use NEXT_PUBLIC_*.
APP_PASSCODE=

# Browser calls the authenticated same-origin relay.
NEXT_PUBLIC_API_URL=/api/backend
# Server-only absolute Render backend origin.
BACKEND_API_URL=http://localhost:4000
# Optional comma-separated development origins.
NEXT_PUBLIC_DEV_ORIGINS=localhost:3000
