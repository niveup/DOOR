# ---- Frontend environment ----
# Copy to .env.local and fill in. Do NOT commit real secrets.

# REQUIRED. Password used to encrypt the iron-session cookie.
# Must be at least 32 characters. The app throws on boot if this is missing.
SESSION_SECRET=

# REQUIRED. Your login passcode. There is no default; login fails without it.
APP_PASSCODE=

# Backend API base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# OPTIONAL. Comma-separated dev origins allowed by Turbopack when accessing
# the dev server over your LAN, e.g. "192.168.1.42:3000,localhost:3000".
NEXT_PUBLIC_DEV_ORIGINS=localhost:3000
