# Vercel production variables
NODE_ENV=production
# 32+ random characters, used to sign the private session cookie.
SESSION_SECRET=
# 8+ characters. Use the exact same value on the backend host.
APP_PASSCODE=
# Separate 12+ character passcode for the journal. It is never exposed to the browser bundle.
JOURNAL_PASSCODE=
# The private journal re-locks after this many minutes (5-60).
JOURNAL_UNLOCK_DURATION_MINUTES=15
# 32+ random characters used only to encrypt journal payloads before they are written to D1.
JOURNAL_ENCRYPTION_KEY=
# HTTPS URL of the deployed journal-store Worker and its shared HMAC secret.
CF_JOURNAL_STORE_URL=
CF_JOURNAL_STORE_SECRET=
# Browser traffic remains same-origin through the authenticated relay.
NEXT_PUBLIC_API_URL=/api/backend
# Absolute URL of the deployed Express backend, for example https://jujum-api.onrender.com
BACKEND_API_URL=
# Development only. Comma-separated origins accepted by Next dev.
NEXT_PUBLIC_DEV_ORIGINS=localhost:3000
