# ---- Frontend environment ----
# Copy to .env.local and fill in. Do NOT commit real secrets.

# REQUIRED. Password used to encrypt the iron-session cookie (32+ chars).
SESSION_SECRET=

# REQUIRED. Strong shared secret used for login and server-to-server backend
# relay authentication. Set the identical value in Render. Never expose it as
# NEXT_PUBLIC_*. Use at least 8 characters; 16+ random characters is better.
APP_PASSCODE=

# Browser requests stay same-origin. Keep this value exactly as shown in Vercel.
NEXT_PUBLIC_API_URL=/api/backend

# Server-only Render backend origin, e.g. https://your-service.onrender.com
BACKEND_API_URL=http://localhost:4000

# OPTIONAL. Comma-separated development origins.
NEXT_PUBLIC_DEV_ORIGINS=localhost:3000
